{
  "name": "aerolink-key-manager",
  "version": "1.0.0",
  "description": "Production-ready API Key Manager & local proxy for Aerolink / Claude Code",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "cd dashboard && npm install && npm run build",
    "start": "node dist/proxy/start.js",
    "proxy": "node dist/proxy/start.js",
    "proxy:dev": "node --watch dist/proxy/start.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION_TEST=true vitest run src/tests/integration",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^1.1.2",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.15",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "",
  "license": "ISC"
}
