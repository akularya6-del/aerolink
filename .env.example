# ============================================================
#  Aerolink Key Manager — Environment Configuration
# ============================================================

# Aerolink upstream API base URL
AEROLINK_BASE_URL=https://capi.aerolink.lat

# Default model (passed through if not overridden by client)
AEROLINK_MODEL=claude-sonnet-4-6

# ============================================================
#  API Keys — add as many as needed (AEROLINK_KEY_1, _2, ...)
# ============================================================
AEROLINK_KEY_1=aero_live_REPLACE_ME
AEROLINK_KEY_2=aero_live_REPLACE_ME
AEROLINK_KEY_3=aero_live_REPLACE_ME
# AEROLINK_KEY_4=...
# AEROLINK_KEY_5=...

# ============================================================
#  Proxy Server
# ============================================================
# Port the local proxy listens on (Claude Code will point here)
PROXY_PORT=3000

# ============================================================
#  Key Manager Tuning
# ============================================================
# How long a rate-limited key stays in cooldown (default: 5 hours)
COOLDOWN_DURATION_MS=18000000

# Max retry attempts for transient 5xx errors
RETRY_COUNT=3

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

# Max simultaneous in-flight requests
MAX_CONCURRENT_REQUESTS=100

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Persistent state file path
STATE_FILE=keys-state.json
